@model Web.Models.EmployeeViewModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create Employee</h1>

<h4>EmployeeViewModel</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">@Html.DisplayNameFor(model => model.LastName)</label>
                <div class="col-sm-10">
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">@Html.DisplayNameFor(model => model.FirstName)</label>
                <div class="col-sm-10">
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">@Html.DisplayNameFor(model => model.MiddleName)</label>
                <div class="col-sm-10">
                    <input asp-for="MiddleName" class="form-control" />
                    <span asp-validation-for="MiddleName" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">@Html.DisplayNameFor(model => model.DateOfBirth)</label>
                <div class="col-sm-10">
                    <input asp-for="DateOfBirth" class="form-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">@Html.DisplayNameFor(model => model.DailyRate)</label>
                <div class="col-sm-10">
                    <input asp-for="DailyRate" class="form-control" />
                    <span asp-validation-for="DailyRate" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label class="col-sm-2 col-form-label">@Html.DisplayNameFor(model => model.WorkingDays)</label>
                <div class="col-sm-10">
                    <select asp-for="WorkingDays" class="form-select">
                        <option value="MWF">MWF (Monday, Wednesday, Friday)</option>
                        <option value="TTHS">TTHS (Tuesday, Thursday)</option>
                    </select>
                    <span asp-validation-for="WorkingDays" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-10 offset-sm-2">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>